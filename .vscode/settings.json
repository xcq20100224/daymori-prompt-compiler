{
    "files.associations": {
        "*.mjs": "javascript"
    },
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit"
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/docs/benchmarks/results/exports/**/*.pptx": true
    },
    "files.watcherExclude": {
        "**/docs/benchmarks/results/exports/**": true
    }
}