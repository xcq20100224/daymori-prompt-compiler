LLM_PROVIDER=deepseek
LLM_MODEL=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
ZHIPU_API_KEY=
OPENAI_API_KEY=
AIPPT_API_ENDPOINT=
AIPPT_API_KEY=
AIPPT_API_MODEL=
AIPPT_PROVIDER=generic
# options: generic | openai-compatible | openai | lazyman
# when AIPPT_PROVIDER=lazyman, you can set LAZYMAN_API_ENDPOINT and keep AIPPT_API_ENDPOINT empty
LAZYMAN_API_ENDPOINT=
AIPPT_API_AUTH_MODE=bearer
AIPPT_API_KEY_HEADER=x-api-key
AIPPT_API_EXTRA_HEADERS=
ALLOWED_ORIGINS=
AUDIT_LOG_ENABLED=true
AUDIT_LOG_DIR=./logs
AUDIT_SALT=
PORT=3000
