{
    "version": "1.0",
    "qualityGate": {
        "minScore": 95,
        "maxRetries": 3,
        "blockers": {
            "watermark": {
                "patterns": [
                    "内容由AI生成",
                    "由AI生成",
                    "OfficePLUS",
                    "LOGO",
                    "CONTENT",
                    "请在此输入",
                    "输入标题",
                    "placeholder"
                ],
                "maxOccurrences": 0,
                "severity": "CRITICAL"
            },
            "pageNumber": {
                "patterns": [
                    "/\\b\\d+\\s*\\/\\s*\\d+\\b/",
                    "第\\s*\\d+\\s*页",
                    "Page\\s*\\d+"
                ],
                "maxOccurrences": 0,
                "severity": "CRITICAL"
            },
            "halfFilled": {
                "minTextPerSlide": 100,
                "maxEmptyRatio": 0.15,
                "severity": "HIGH"
            },
            "titleDuplicate": {
                "maxSimilarity": 0.7,
                "severity": "MEDIUM"
            }
        }
    },
    "contentRules": {
        "slidesPerTopic": {
            "min": 10,
            "max": 20
        },
        "keyPointsPerSlide": {
            "min": 3,
            "max": 5
        },
        "textLengthPerPoint": {
            "min": 15,
            "max": 50
        }
    },
    "template": {
        "enforceClean": true,
        "allowedTemplates": [
            "docs/benchmarks/templates/inbox/clean-lazyman.pptx",
            "docs/benchmarks/templates/inbox/blank-clean.pptx"
        ]
    }
}